    {
      "name": "Creators",
      "item": [
        {
          "name": "GET /creators — public",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Returns array', () => pm.expect(body.data).to.be.an('array'));",
                  "pm.test('No passwordHash in any user', () => {",
                  "  body.data.forEach(c => pm.expect(c.user).to.not.have.property('passwordHash'));",
                  "});",
                  "if (body.data.length > 0) {",
                  "  pm.collectionVariables.set('creatorProfileId', body.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/creators"
          }
        },
        {
          "name": "GET /creators/:id — valid",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Returns creator with socialAccounts', () => pm.expect(body.data.socialAccounts).to.be.an('array'));",
                  "pm.test('No passwordHash in user', () => pm.expect(body.data.user).to.not.have.property('passwordHash'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/creators/{{creatorProfileId}}"
          }
        },
        {
          "name": "GET /creators/:id — not found (expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/creators/00000000-0000-0000-0000-000000000000"
          }
        },
        {
          "name": "PATCH /creators/:id — own token (expect 200)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('baseUrl') + '/auth/login',",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json' },",
                  "  body: { mode: 'raw', raw: JSON.stringify({ email: 'creator@collabhub.com', password: 'password123' }) }",
                  "}, (err, res) => {",
                  "  const body = res.json();",
                  "  pm.collectionVariables.set('creatorAccessToken', body.data.accessToken);",
                  "  pm.collectionVariables.set('creatorRefreshToken', body.data.refreshToken);",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Bio is updated', () => pm.expect(body.data.bio).to.equal('Updated bio via Postman'));",
                  "pm.test('Age is updated', () => pm.expect(body.data.age).to.equal(27));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/creators/{{creatorProfileId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{creatorAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Updated bio via Postman\",\n  \"age\": 27\n}"
            }
          }
        },
